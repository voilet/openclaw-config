# OpenClaw Secrets Template
# Copy this file to secrets.env and fill in your actual values
# NEVER commit secrets.env to git!

# BigModel API (智谱 AI)
BIGMODEL_API_KEY=your_bigmodel_api_key_here

# Telegram Bot Tokens
TELEGRAM_BOT_TOKEN_1=your_first_telegram_bot_token
TELEGRAM_BOT_TOKEN_2=your_second_telegram_bot_token

# Gateway Authentication
GATEWAY_AUTH_TOKEN=your_secure_gateway_token

# Optional: Other API Keys
# OPENAI_API_KEY=your_openai_key
# ANTHROPIC_API_KEY=your_anthropic_key
